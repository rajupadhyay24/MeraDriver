generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())

  name String?

  email String @unique

  mobile String? @unique

  password String?

  googleId String? @unique

  image String?

  otp String?

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
}

model Category {
  category_id BigInt @id @default(autoincrement())

  category_name String @db.VarChar(255)

  category_slug String @unique @db.VarChar(255)

  category_image String?

  category_description String?

  status CategoryStatus @default(active)

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  deleted_at DateTime?

  subCategories SubCategory[]

  @@map("categories")
}

enum CategoryStatus {
  active
  inactive
}

model SubCategory {
  sub_category_id BigInt @id @default(autoincrement())

  category_id BigInt

  category Category @relation(fields: [category_id], references: [category_id])

  sub_category_name String @db.VarChar(255)

  sub_category_slug String @unique @db.VarChar(255)

  icon String?

  description String?

  status Status @default(active)

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  deleted_at DateTime?

  productCards ProductCard[]

  @@map("sub_categories")
}

model ProductCard {
  product_card_id BigInt @id @default(autoincrement())

  sub_category_id BigInt

  subCategory SubCategory @relation(fields: [sub_category_id], references: [sub_category_id])

  business_name String @db.VarChar(255)

  deal_title String

  short_description String?

  location_name String? @db.VarChar(255)

  address String?

  distance Decimal? @db.Decimal(10, 2)

  rating Decimal? @db.Decimal(2, 1)

  review_count Int?

  original_price Decimal? @db.Decimal(10, 2)

  discounted_price Decimal? @db.Decimal(10, 2)

  discount_percentage Int?

  primary_image String?

  offer_tag String? @db.VarChar(100)

  deal_status DealStatus @default(active)

  total_bought Int?

  company_website String?

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  deleted_at DateTime?

  productDetail ProductDetail?

  @@map("product_cards")
}

model ProductDetail {
  detail_id BigInt @id @default(autoincrement())

  product_card_id BigInt @unique

  productCard ProductCard @relation(fields: [product_card_id], references: [product_card_id])

  about_business String?

  offer_description String?

  what_we_offer String?

  benefits String?

  why_choose_offer String?

  need_to_know String?

  redemption_address String?

  latitude Decimal? @db.Decimal(10, 8)

  longitude Decimal? @db.Decimal(11, 8)

  opening_hours String?

  customer_photos Json?

  customer_videos Json?

  average_rating Decimal? @db.Decimal(2, 1)

  total_reviews Int?

  faq Json?

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  deleted_at DateTime?

  @@map("product_details")
}

enum Status {
  active
  inactive
}

enum DealStatus {
  active
  expired
}
